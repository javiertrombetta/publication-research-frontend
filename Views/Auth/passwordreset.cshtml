@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <link rel="stylesheet" href="/lib/tabler/css/tabler.min.css" />
</head>

<body style="height: 100vh; max-height: 100vh; display: flex; flex-direction: column; overflow: hidden; background-color: var(--tblr-bg-surface); margin: 0;">

    <!-- Navbar -->
    <header class="navbar navbar-expand-md d-print-none bg-white border-bottom">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center">
                <a href="/" class="navbar-brand navbar-brand-autodark">
                    <img src="/pic/AIS logo.png" height="32" class="navbar-brand-image">
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content space stretches dynamically to fill the screen gaps perfectly -->
    <div class="page flex-grow-1 d-flex flex-column justify-content-center" style="min-height: 0;">
        <div id="page-wrapper" class="page-wrapper w-100 d-flex flex-column justify-content-center">
            <main class="page-body m-0 py-4">
                <div class="container-xl">
                    
                    <!-- Centered column arrangement to keep the single form looking balanced and clean -->
                    <div class="row justify-content-center">
                        <div class="col-12 col-sm-9 col-md-7 col-lg-5 col-xl-4">
                            
                            <div class="card card-md shadow-sm">
                                <div class="card-body py-4 px-4">
                                    <h2 class="h2 text-center mb-4">Reset Password</h2>
                                    
                                    <form action="./" method="post" autocomplete="off" novalidate>
                                        
                                        <!-- New Password Field -->
                                        <div class="mb-3">
                                            <label class="form-label mb-2">Enter a new password</label>
                                            <input type="password" class="form-control" placeholder="Choose a fresh secure password" required>
                                            
                                            <!-- Live Strength Progress Bar Indicator Component -->
                                            <div class="progress progress-xs mt-2">
                                                <div class="progress-bar bg-success" style="width: 85%" role="progressbar" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                            <small class="text-secondary d-block mt-2" style="font-size: 0.8rem;">Password status: <span class="text-success fw-bold">Strong password</span></small>
                                        </div>

                                        <!-- Password Confirmation Field -->
                                        <div class="mb-4">
                                            <label class="form-label mb-2">Confirm the password</label>
                                            <input type="password" class="form-control" placeholder="Re-enter the new password" required>
                                        </div>

                                        <!-- Submit Action Button -->
                                        <div class="form-footer mt-2">
                                            <button type="submit" class="btn btn-primary w-100 py-2 fs-3">
                                                <!-- Tabler SVG Lock Icon -->
                                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-lock-check me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                    <path d="M11.5 21h-4.5a2 2 0 0 1 -2 -2v-6a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v.5" />
                                                    <path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" />
                                                    <path d="M8 11v-4a4 4 0 1 1 8 0v4" />
                                                    <path d="M15 19l2 2l4 -4" />
                                                </svg>
                                                Update my password
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted bg-light">
        <div class="container-fluid d-flex justify-content-between align-items-center py-3 px-4">
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="me-3">
                    Privacy Policy
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="me-3">
                    Contact IT
                </a>
            </div>
            <span>&copy; 2026 Auckland Institute of Studies</span>
        </div>
    </footer>

    <script src="/lib/tabler/js/tabler.min.js"></script>
</body>

</html>