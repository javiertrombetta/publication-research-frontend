@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <link rel="stylesheet" href="/lib/tabler/css/tabler.min.css" />
</head>

<!-- Stretches the viewport to exactly 1 screen height, locking scrollbars entirely -->
<body style="height: 100vh; max-height: 100vh; display: flex; flex-direction: column; overflow: hidden; background-color: var(--tblr-bg-surface); margin: 0;">

    <!-- Navbar: Removed fixed-top to allow smooth flex arrangement without content overlap -->
    <header class="navbar navbar-expand-md d-print-none bg-white border-bottom">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center">
                <a href="/" class="navbar-brand navbar-brand-autodark">
                    <img src="/pic/AIS logo.png" height="32" class="navbar-brand-image">
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content space stretches dynamically to fill the screen gaps perfectly -->
    <div class="page flex-grow-1 d-flex flex-column justify-content-center" style="min-height: 0;">
        <div id="page-wrapper" class="page-wrapper w-100 d-flex flex-column justify-content-center">
            <main class="page-body m-0 py-3">
                <div class="container-fluid w-100">

                    <!-- Centered Container -->
                    <div class="container container-tight">
                        
                        <div class="card card-md shadow-sm">
                            <div class="card-body">
                                <h2 class="h2 text-center mb-4">Login to your account</h2>
                                
                                <form action="./" method="post" autocomplete="off" novalidate>
                                    <!-- Email Field -->
                                    <div class="mb-3">
                                        <label class="form-label">Email address</label>
                                        <input type="email" class="form-control" placeholder="your@email.com" autocomplete="off" required>
                                    </div>
                                    
                                    <!-- Password Field with Forgot Password Option -->
                                    <div class="mb-2">
                                        <label class="form-label d-flex justify-content-between align-items-center">
                                            <span>Password</span>
                                            <span class="form-label-description font-weight-normal fs-5">
                                                <a href="./forgot-password.html">I forgot password</a>
                                            </span>
                                        </label>
                                        <input type="password" class="form-control" placeholder="Your password" autocomplete="off" required>
                                    </div>
                                    
                                    <!-- Remember Me Checkbox -->
                                    <div class="mb-3">
                                        <label class="form-check">
                                            <input type="checkbox" class="form-check-input"/>
                                            <span class="form-check-label">Remember me on this device</span>
                                        </label>
                                    </div>
                                    
                                    <!-- Submit Button -->
                                    <div class="form-footer">
                                        <button type="submit" class="btn btn-primary w-100">Sign in</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        
                        <!-- Sign Up Link -->
                        <div class="text-center text-secondary mt-3">
                            Don't have an account yet? <a href="./sign-up.html" tabindex="-1">Sign up</a>
                        </div>

                    </div>

                </div>
            </main>
        </div>
    </div>

    <!-- Footer: Stays pinned cleanly at the bottom of the visible display screen -->
    <footer class="border-top footer text-muted bg-light">
        <div class="container-fluid d-flex justify-content-between align-items-center py-3 px-4">
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="me-3">
                    Privacy Policy
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="me-3">
                    Contact IT
                </a>
            </div>
            <span>&copy; 2026 Auckland Institute of Studies</span>
        </div>
    </footer>

    <script src="/lib/tabler/js/tabler.min.js"></script>
</body>

</html>







