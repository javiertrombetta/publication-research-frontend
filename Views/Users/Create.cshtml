@model CreateUserViewModel
@using ResearchPublicationManagementSystem.Models

@{
    ViewData["Title"] = "Create User";
}

<partial name="_PageHeader"
         model='new PageHeaderViewModel
         {
             Title = "Create User",
             Subtitle = "Create a new system user."
         }' />
         <form asp-action="Create" method="post">
<div class="card mt-4">
    <div class="card-body">

        <h3 class="card-title mb-4">
            Personal Information
        </h3>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Department" class="form-label"></label>
                <input asp-for="Department" class="form-control" />
            </div>

        </div>

    </div>
</div>
<div class="card mt-4">
    <div class="card-body">

        <h3 class="card-title mb-4">
            Account Information
        </h3>

        <div class="row">

                <div class="mb-3">
                    <label class="form-label fw-bold">Assigned Roles</label>

                    <div class="row">

                        <div class="col-md-6">

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleStudent">
                                <label class="form-check-label" for="roleStudent">
                                    Student
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleSupervisor">
                                <label class="form-check-label" for="roleSupervisor">
                                    Supervisor
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleHOD">
                                <label class="form-check-label" for="roleHOD">
                                    Head of Department
                                </label>
                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleCommittee">
                                <label class="form-check-label" for="roleCommittee">
                                    Committee Member
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleCoordinator">
                                <label class="form-check-label" for="roleCoordinator">
                                    Research Coordinator
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="roleAdmin">
                                <label class="form-check-label" for="roleAdmin">
                                    Administrator
                                </label>
                            </div>

                        </div>

                    </div>
                </div>
            <div class="col-md-6 mb-3">

                <label class="form-label">
                    Status
                </label>

                <div class="form-check mt-2">

                    <input asp-for="IsActive"
                           class="form-check-input" />

                    <label asp-for="IsActive"
                           class="form-check-label">
                        Active User
                    </label>

                </div>

            </div>

        </div>

    </div>
</div>
<div class="card mt-4">
    <div class="card-body">

        <h3 class="card-title mb-4">
            Account Security
        </h3>

        <div class="row">

            <div class="col-md-6 mb-3">

                <label asp-for="Password"
                       class="form-label"></label>

                <input asp-for="Password"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="ConfirmPassword"
                       class="form-label"></label>

                <input asp-for="ConfirmPassword"
                       class="form-control" />

            </div>

        </div>

    </div>
</div>
<div class="d-flex justify-content-end gap-2 mt-4">

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

    <button type="submit"
            class="btn btn-primary">

        <i class="ti ti-device-floppy"></i>

        Create User

    </button>

</div>
</form>