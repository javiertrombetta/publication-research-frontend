@model ResearchPublicationManagementSystem.Models.DashboardViewModel

<div class="card h-100">

    <div class="card-header">
        <h3 class="card-title fw-bold">
            Latest Workflow Updates
        </h3>
    </div>

    <div class="card-body">

        <div class="mb-4">

            <span class="badge bg-success me-2">Approved</span>

            <div class="fw-bold mt-2">
                Publication #PUB-2024-089 approved for publication
            </div>

            <small class="text-secondary">
                Today, 09:20 AM
            </small>

        </div>

        <div class="mb-4">

            <span class="badge bg-success me-2">Verified</span>

            <div class="fw-bold mt-2">
                Ethics declaration verified
            </div>

            <small class="text-secondary">
                Today, 08:55 AM
            </small>

        </div>

        <div class="mb-4">

            <span class="badge bg-danger me-2">Pending</span>

            <div class="fw-bold mt-2">
                Peer review assignment pending
            </div>

            <small class="text-secondary">
                Today, 08:30 AM
            </small>

        </div>

        <div class="mb-4">

            <span class="badge bg-warning text-dark me-2">
                Waiting
            </span>

            <div class="fw-bold mt-2">
                Proposal awaiting ethics review
            </div>

            <small class="text-secondary">
                Yesterday, 04:15 PM
            </small>

        </div>

        <div>

            <span class="badge bg-primary me-2">
                Updated
            </span>

            <div class="fw-bold mt-2">
                System settings update requested
            </div>

            <small class="text-secondary">
                Yesterday, 02:00 PM
            </small>

        </div>

    </div>

</div>