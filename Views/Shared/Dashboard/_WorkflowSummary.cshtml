@model ResearchPublicationManagementSystem.Models.DashboardViewModel

<div class="card">

    <div class="card-header">
        <h3 class="card-title fw-bold">
            Workflow Summary
        </h3>
    </div>

    <div class="card-body">

        <!-- Proposal Assignment -->

        <div class="mb-4">

            <div class="d-flex justify-content-between mb-1">

                <strong>Proposal Assignment</strong>

                <span class="badge bg-danger">
                    12 Pending
                </span>

            </div>

            <div class="progress progress-sm">

                <div class="progress-bar bg-danger"
                     style="width:30%"></div>

            </div>

            <small class="text-secondary">
                12 of 40 items require attention
            </small>

        </div>

        <!-- Ethics Approval -->

        <div class="mb-4">

            <div class="d-flex justify-content-between mb-1">

                <strong>Ethics Approval</strong>

                <span class="badge bg-warning">
                    8 Pending
                </span>

            </div>

            <div class="progress progress-sm">

                <div class="progress-bar bg-warning"
                     style="width:27%"></div>

            </div>

            <small class="text-secondary">
                8 of 30 items require attention
            </small>

        </div>

        <!-- Publication Approval -->

        <div>

            <div class="d-flex justify-content-between mb-1">

                <strong>Publication Approval</strong>

                <span class="badge bg-primary">
                    15 Pending
                </span>

            </div>

            <div class="progress progress-sm">

                <div class="progress-bar bg-primary"
                     style="width:30%"></div>

            </div>

            <small class="text-secondary">
                15 of 50 items require attention
            </small>

        </div>

    </div>

</div>