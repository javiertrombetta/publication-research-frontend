@model ResearchPublicationManagementSystem.Models.DashboardViewModel

<div class="card">

    <div class="card-header">

        <h3 class="card-title fw-bold">

            Publication Overview

        </h3>

    </div>

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <strong>Proposal Submitted</strong>

                <div class="text-secondary small">
                    Waiting for supervisor approval
                </div>

            </div>

            <span class="badge bg-primary-lt text-primary">
                35
            </span>

        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <strong>Under Review</strong>

                <div class="text-secondary small">
                    Committee review in progress
                </div>

            </div>

            <span class="bg-warning-lt text-warning">
                18
            </span>

        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <strong>Accepted</strong>

                <div class="text-secondary small">
                    Ready for Publication
                </div>

            </div>

            <span class="bg-success-lt text-success">
                55
            </span>

        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <strong>Revision</strong>

                <div class="text-secondary small">
                    Require Resubmission
                </div>

            </div>

            <span class="bg-purple-lt text-purple">
                2
            </span>

        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <strong>Published</strong>

                <div class="text-secondary small">
                    Visible to public catalogue
                </div>

            </div>

            <span class="bg-info-lt text-info">
                30
            </span>

        </div>

    </div>

</div>
