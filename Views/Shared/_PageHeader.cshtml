@model ResearchPublicationManagementSystem.Models.PageHeaderViewModel

<div class="page-header mb-4">

    <div>

        <h1 class="page-title fw-bold">

            @Model.Title

        </h1>

        @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
        {
            <div class="text-secondary mt-2">

                @Model.Subtitle

            </div>
        }

    </div>

</div>