

            <main class="page-body m-0 py-4">
                <div class="container-xl">
                    
                    <!-- Form Wrapper for Assignment Submission -->
                    <form id="assignSupervisorForm" action="#" method="POST" class="row justify-content-center row-cards">
                        
                        <!-- Page Header -->
                        <div class="col-12 col-lg-11 col-xl-10 mb-3">
                            <div class="d-flex justify-content-between align-items-center px-2">
                                <div>
                                    <h1 class="h1 m-0 fw-bold text-dark">Assigning a Proposal to Supervisor</h1>
                                </div>
                            </div>
                        </div>

                        <!-- Single Column Container for All Cards -->
                        <div class="col-12 col-lg-11 col-xl-10 d-flex flex-column gap-4">
                            
                            <!-- 1. Proposal & Student Metadata Card -->
                            <div class="card shadow-sm">
                                <div class="card-header bg-light py-3">
                                    <h3 class="card-title fw-bold text-dark">Proposal Details</h3>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label text-secondary small fw-bold text-uppercase mb-1">Proposal Title</label>
                                        <div class="text-dark fw-bold fs-3 lh-base">An Analysis of Smart Home Cryptographic Vulnerabilities in Edge Computing Environments</div>
                                    </div>
                                    
                                    <hr class="my-3" />
                                    
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <label class="form-label text-secondary small fw-bold text-uppercase mb-1">Student Name</label>
                                            <div class="text-dark fw-medium">Alex Chen</div>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label text-secondary small fw-bold text-uppercase mb-1">Student ID</label>
                                            <div class="text-dark font-monospace">STU-2026-8941</div>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label text-secondary small fw-bold text-uppercase mb-1">Date Submitted</label>
                                            <div class="text-dark">July 20, 2026</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 2. Abstract Card -->
                            <div class="card shadow-sm">
                                <div class="card-header bg-light py-3">
                                    <h3 class="card-title fw-bold text-dark">Abstract</h3>
                                </div>
                                <div class="card-body">
                                    <p class="text-secondary lh-lg m-0" style="text-align: justify; font-size: 0.92rem;">
                                        This research proposal outlines a comprehensive security evaluation of public and private key infrastructure deployed across modern IoT smart home frameworks. By analyzing potential edge execution nodes, the study aims to identify cryptographic latency trade-offs alongside physical and data-driven security configurations. The experimental design relies entirely on simulated machine states and open-source protocol packages.
                                    </p>
                                </div>
                            </div>

                            <!-- 3. Supervisor Allocation Card -->
                            <div class="card shadow-sm border-top border-primary">
                                <div class="card-header bg-light py-3">
                                    <h3 class="card-title fs-2 fw-bold text-primary">Assign a supervisor to this proposal</h3>
                                </div>
                                <div class="card-body py-4">
                                    
                                    <!-- Dropdown Selection Menu -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold text-dark mb-2">Select Faculty Supervisor</label>
                                        <select class="form-select text-dark" name="supervisor_id" required>
                                            <option value="" disabled selected hidden>Choose a supervisor from the registry...</option>
                                            <option value="1">Dr. Sarah Jenkins (Cybersecurity & Cryptography)</option>
                                            <option value="2">Prof. Michael Fowler (Edge Systems & IoT Architecture)</option>
                                            <option value="3">Dr. Elena Rostova (Data Privacy & Machine States)</option>
                                            <option value="4">Dr. James Vance (Network Protocol & Security Infrastructures)</option>
                                        </select>
                                    </div>

                                    <!-- Internal Coordinator Allocation Notes -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold text-dark mb-1">Allocation Notes (Optional)</label>
                                        <textarea class="form-control text-dark" rows="3" placeholder="Add optional comments regarding special workload balancing or expertise matching criteria..."></textarea>
                                    </div>
                                    
                                    <hr class="my-4" />

                                    <!-- Bottom Control Operations Actions -->
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-outline-secondary px-3" onclick="window.history.back();">Cancel</button>
                                        <button type="submit" name="action" value="assign" class="btn btn-primary px-4 fw-bold">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user-plus me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M16 19h6" /><path d="M19 16v6" /><path d="M6 21v-2a4 4 0 0 1 4 -4h4" /></svg>
                                            Confirm Assignment
                                        </button>
                                    </div>
                                    
                                </div>
                            </div>

                        </div>
                    </form>

                </div>
            </main>
  

