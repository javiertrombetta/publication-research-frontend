
    <!-- Main Content space stretches dynamically to fill the screen gaps perfectly -->
    <div class="page flex-grow-1 d-flex flex-column justify-content-center" style="min-height: 0;">
        <div id="page-wrapper" class="page-wrapper w-100 d-flex flex-column justify-content-center">
            <main class="page-body m-0 py-4">
                <div class="container-xl">
                    
                    <!-- Centered responsive layout wrapper -->
                    <form action="#" method="POST" class="row justify-content-center">
                        <div class="col-12 col-md-10 col-lg-8 col-xl-7">
                            
                            <!-- Minimal Text-Only Header (No card, no circle avatar) -->
                            <div class="mb-4 px-2">
                                <h1 class="h1 m-0 fw-bold text-dark">Edit your profile</h1>
                            </div>

                            <!-- Interactive Account Configuration Grid -->
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h3 class="card-title fs-2 fw-bold">Academic Profile Details</h3>
                                </div>
                                <div class="card-body py-4 px-4">
                                    <div class="row g-3">
                                        
                                        <!-- Name Form input -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">First Name</label>
                                            <input type="text" class="form-control" name="FirstName" value="John" placeholder="Enter first name" required>
                                        </div>

                                        <!-- Surname Form input -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Surname</label>
                                            <input type="text" class="form-control" name="Surname" value="Doe" placeholder="Enter surname" required>
                                        </div>

                                        <!-- Student ID Form element (Set to Disabled/Readonly state for identity security) -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Student ID (Immutable)</label>
                                            <input type="text" class="form-control bg-transparent text-primary fw-bold" value="AIS-2026-8942" readonly disabled>
                                        </div>

                                        <!-- Cohort Standard Text Input Field -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Cohort</label>
                                            <input type="text" class="form-control" name="Cohort" value="2026 - Intake A" placeholder="Enter cohort batch" required>
                                        </div>

                                        <!-- Course / Program Form input -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Program / Course</label>
                                            <input type="text" class="form-control" name="ProgramCourse" value="B.Sc. in Computer Science" placeholder="Enter program or course name" required>
                                        </div>

                                        <!-- Department Form input -->
                                        <div class="col-6">
                                            <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Department</label>
                                            <input type="text" class="form-control" name="Department" value="Information Technology" placeholder="Enter academic department" required>
                                        </div>

                                    </div>
                                </div>
                                
                                <!-- Bottom Actions Footer -->
                                <div class="card-footer bg-transparent d-flex justify-content-end align-items-center gap-3 py-3 px-4">
                                    <a href="./profile.html" class="btn btn-link text-secondary text-decoration-none m-0 p-2">
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary px-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-check me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10" /></svg>
                                        Save Changes
                                    </button>
                                </div>
                            </div>

                        </div>
                    </form>

                </div>
            </main>
        </div>
    </div>

