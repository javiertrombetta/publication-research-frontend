

            <main class="page-body m-0 py-4">
                <div class="container-xl">
                    
                    <!-- Centered responsive layout wrapper -->
                    <form action="#" method="POST" class="row justify-content-center">
                        <div class="col-12 col-md-10 col-lg-8 col-xl-7">
                            
                            <!-- Minimal Text-Only Header with Limit Context -->
                            <div class="d-flex justify-content-between align-items-end mb-3 px-2">
                                <div>
                                    <h1 class="h1 m-0 fw-bold text-dark">Create new proposals</h1>
                                    <p class="text-secondary small m-0">Fill out up to 3 alternative proposals below.</p>
                                </div>
                            </div>

                            <!-- Interactive Tab Navigation Header for 3 Slots -->
                            <div class="card shadow-sm">
                                <ul class="nav nav-tabs (card-header-tabs) m-0 bg-light border-bottom" data-bs-toggle="tabs" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <a href="#tabs-proposal-1" class="nav-index nav-link active py-3 px-4 fw-bold" data-bs-toggle="tab" role="tab">
                                            <span class="badge bg-primary-lt me-2">1</span> Proposal One
                                        </a>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <a href="#tabs-proposal-2" class="nav-link py-3 px-4 fw-bold" data-bs-toggle="tab" role="tab">
                                            <span class="badge bg-secondary-lt me-2">2</span> Proposal Two
                                        </a>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <a href="#tabs-proposal-3" class="nav-link py-3 px-4 fw-bold" data-bs-toggle="tab" role="tab">
                                            <span class="badge bg-secondary-lt me-2">3</span> Proposal Three
                                        </a>
                                    </li>
                                </ul>

                                <!-- Dynamic Tab Contents Workspace -->
                                <div class="tab-content">
                                    
                                    <!-- 1st Proposal Workspace Panel -->
                                    <div class="tab-pane fade active show" id="tabs-proposal-1" role="tabpanel">
                                        <div class="card-body py-4 px-4">
                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Proposal Title</label>
                                                    <input type="text" class="form-control form-control-lg" name="ProposalTitle1" placeholder="Enter a descriptive title for your first proposal" required maxlength="150">
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Abstract (Max 2,000 words)</label>
                                                    <textarea class="form-control" name="ProposalAbstract1" rows="6" placeholder="Provide a concise summary outlining the core objectives, methodology, and expected outcomes..." required style="resize: none;"></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 2nd Proposal Workspace Panel -->
                                    <div class="tab-pane fade" id="tabs-proposal-2" role="tabpanel">
                                        <div class="card-body py-4 px-4">
                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Proposal Title</label>
                                                    <input type="text" class="form-control form-control-lg" name="ProposalTitle2" placeholder="Enter a descriptive title for your second proposal" maxlength="150">
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Abstract (Max 2,000 words)</label>
                                                    <textarea class="form-control" name="ProposalAbstract2" rows="6" placeholder="Provide a concise summary outlining the core objectives, methodology, and expected outcomes..." style="resize: none;"></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 3rd Proposal Workspace Panel -->
                                    <div class="tab-pane fade" id="tabs-proposal-3" role="tabpanel">
                                        <div class="card-body py-4 px-4">
                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Proposal Title</label>
                                                    <input type="text" class="form-control form-control-lg" name="ProposalTitle3" placeholder="Enter a descriptive title for your third proposal" maxlength="150">
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label text-secondary mb-1 uppercase tracking-wider small fw-bold">Abstract (Max 2,000 words)</label>
                                                    <textarea class="form-control" name="ProposalAbstract3" rows="6" placeholder="Provide a concise summary outlining the core objectives, methodology, and expected outcomes..." style="resize: none;"></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <!-- Sticky Shared Action Button Footer Container -->
                                <div class="card-footer bg-transparent border-top d-flex justify-content-end align-items-center gap-3 py-3 px-4">
                                    <a href="./proposals-list.html" class="btn btn-link text-secondary text-decoration-none m-0 p-2">
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary px-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-plus me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
                                        Submit All Proposals
                                    </button>
                                </div>
                            </div>

                        </div>
                    </form>

                </div>
            </main>
  

